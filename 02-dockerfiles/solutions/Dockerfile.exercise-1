# Solution - Exercise 2.1 Containerize the App
# Build from the repo root:  docker build -f 02-dockerfiles/solutions/Dockerfile.exercise-1 -t lab-app:1 .

FROM python:3.12-slim

WORKDIR /app

# Copy requirements first so this layer is cached until they change
COPY app/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Then copy the rest of the application code
COPY app/ .

ENV APP_ENV=production
EXPOSE 5000

CMD ["python", "app.py"]
